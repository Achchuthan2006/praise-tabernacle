NEXT_PUBLIC_SITE_URL=https://praisetabernacle.org
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
RESEND_API_KEY=
RSVP_FROM_EMAIL=
# Legacy alias also supported:
# NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Optional: YouTube Data API v3 server-side sermon sync
# Create an API key in Google Cloud Console with YouTube Data API v3 enabled.
# The site will use this to fetch real videos from the uploads playlist configured in lib/site.ts.
YOUTUBE_API_KEY=

# Giving platform configuration
# Add your church's real hosted giving URL here.
# Supported examples:
# Tithe.ly
# NEXT_PUBLIC_GIVING_PROCESSOR_NAME=Tithe.ly
# NEXT_PUBLIC_GIVING_ONLINE_URL=https://give.tithe.ly/?formId=YOUR_FORM_ID
# NEXT_PUBLIC_GIVING_RECURRING_URL=https://give.tithe.ly/?formId=YOUR_FORM_ID&frequency=monthly
#
# Church Center / Planning Center
# NEXT_PUBLIC_GIVING_PROCESSOR_NAME=Church Center
# NEXT_PUBLIC_GIVING_ONLINE_URL=https://YOUR_CHURCH.churchcenter.com/giving
# NEXT_PUBLIC_GIVING_RECURRING_URL=https://YOUR_CHURCH.churchcenter.com/giving
#
# PayPal hosted donations
# NEXT_PUBLIC_GIVING_PROCESSOR_NAME=PayPal
# NEXT_PUBLIC_GIVING_ONLINE_URL=https://www.paypal.com/donate/?hosted_button_id=YOUR_BUTTON_ID
# NEXT_PUBLIC_GIVING_RECURRING_URL=https://www.paypal.com/donate/?hosted_button_id=YOUR_BUTTON_ID
#
# Stripe payment link
# NEXT_PUBLIC_GIVING_PROCESSOR_NAME=Stripe
# NEXT_PUBLIC_GIVING_ONLINE_URL=https://buy.stripe.com/YOUR_PAYMENT_LINK
# NEXT_PUBLIC_GIVING_RECURRING_URL=https://buy.stripe.com/YOUR_RECURRING_LINK
#
# Optional text-to-give details
# NEXT_PUBLIC_GIVING_TEXT_NUMBER=14165550000
# NEXT_PUBLIC_GIVING_TEXT_KEYWORD=GIVE
NEXT_PUBLIC_GIVING_PROCESSOR_NAME=
NEXT_PUBLIC_GIVING_ONLINE_URL=
NEXT_PUBLIC_GIVING_RECURRING_URL=
NEXT_PUBLIC_GIVING_TEXT_NUMBER=
NEXT_PUBLIC_GIVING_TEXT_KEYWORD=GIVE
